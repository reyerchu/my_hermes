# zero-token / hermes-agent secrets — copy to .env_local (or to ~/.hermes/.env) and fill in.
# Real values must NEVER be committed. .env_local is in .gitignore.

# ─── Telegram (RYClaw or your own bot) ──────────────────────────────────
# Get a bot token from @BotFather. Allowed-users is a CSV of Telegram user IDs.
# Find your ID by DM'ing @userinfobot.
# Setting allowlist to "*" exposes your machine to anyone — do NOT do that.
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_ALLOWED_USERS=your-telegram-user-id

# ─── Discord / WhatsApp / Slack / Signal (optional) ─────────────────────
# Configure only if you actually need that channel; see hermes-agent docs.
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# WHATSAPP_...=

# ─── Claude Code OAuth ──────────────────────────────────────────────────
# Normally NOT needed here: `claude` reads ~/.claude/.credentials.json itself.
# Set this only if you want hermes-agent's *built-in* anthropic provider to
# use an OAuth setup-token instead of the local CLI subprocess.
# ANTHROPIC_TOKEN=sk-ant-oat01-...

# ─── claude_web_proxy.py legacy variables (only if you use the browser proxy) ─
# CLAUDE_WEB_CDP_URL=http://127.0.0.1:9222
# CLAUDE_WEB_AUTH_FILE=/home/<you>/openclaw-zero-token/.openclaw-upstream-state/agents/main/agent/auth-profiles.json
